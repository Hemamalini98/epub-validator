{
  "rules": [
    {
      "id": "URL001",
      "name": "Validate Internal XHTML Links",
      "function": "validate_internal_xhtml_links",
      "target_path": "OEBPS/xhtml",
      "enabled": true,
      "file_name_pattern": ["*_chapter*.xhtml", "*_ch*.xhtml"]
    },
    {
      "id": "URL002",
      "name": "Validate External URLs",
      "function": "validate_external_urls",
      "target_path": "OEBPS/xhtml",
      "enabled": true,
      "file_name_pattern": ["*_chapter*.xhtml", "*_ch*.xhtml"]
    },
    {
      "id": "URL003",
      "name": "Validate URL Text Match",
      "function": "validate_url_text_match",
      "target_path": "OEBPS/xhtml",
      "enabled": true,
      "file_name_pattern": ["*_chapter*.xhtml", "*_ch*.xhtml"]
    },
    {
      "id": "NAV001",
      "name": "Validate NAV TOC Headings",
      "function": "validate_nav_headings",
      "target_path": "",
      "enabled": true,
      "file_name_pattern": "nav.xhtml"
    },
    {
      "id": "CSS001",
      "name": "Validate CSS Files via W3C Validator",
      "function": "validate_css_w3c",
      "target_path": "OEBPS/xhtml",
      "enabled": true,
      "file_name_pattern": ["*_chapter*.xhtml", "*_ch*.xhtml"]
    },
    {
      "id": "CSS002",
      "name": "Validate CSS Files Directly via W3C Validator",
      "function": "validate_css_w3c",
      "target_path": "OEBPS/css",
      "enabled": true,
      "file_name_pattern": "*.css"
    }
  ]
}
